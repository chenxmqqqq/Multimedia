<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".MainActivity">

    <!-- 标题 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RK Android 14 Mediacodec Demo"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- 操作按钮栏 -->
    <LinearLayout
        android:id="@+id/ll_operation_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title">

        <Button
            android:id="@+id/btn_request_permission"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="Request permission"/>

        <Button
            android:id="@+id/btn_scan_videos"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="Scan video"/>

        <Spinner
            android:id="@+id/sp_video_index"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btn_detect_format"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Detection format"/>
    </LinearLayout>

    <!-- 解码/编码按钮栏 -->
    <LinearLayout
        android:id="@+id/ll_codec_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_operation_buttons">

        <Button
            android:id="@+id/btn_hardware_decode"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="decoding"/>

        <Button
            android:id="@+id/btn_hardware_encode"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="encoding"/>
    </LinearLayout>

    <!-- 结果文本 + CPU环形图 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/ll_codec_buttons"
        app:layout_constraintBottom_toBottomOf="parent">

        <ScrollView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:layout_marginRight="24dp"
            android:background="@android:color/transparent"
            android:padding="12dp">

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="操作结果将显示在这里...\n1. 先扫描视频并选中\n2. 点击解码按钮得到原始帧\n3. 点击编码按钮转码为H.265"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:textColor="#333333"
                android:background="@android:color/transparent"/>

        </ScrollView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <!-- 缩小扇形图尺寸，从200dp改为160dp -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/donut_chart_cpu"
                android:layout_width="160dp"
                android:layout_height="160dp"/>

            <TextView
                android:id="@+id/tv_cpu_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU 总占用"
                android:textSize="16sp"
                android:layout_marginTop="12dp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>